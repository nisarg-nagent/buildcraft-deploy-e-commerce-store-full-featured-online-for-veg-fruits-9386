# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=8001
HOST=0.0.0.0

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/myapp

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
